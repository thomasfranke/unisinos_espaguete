olumn(\n            mainAxisAlignment: MainAxisAlignment.center,\n            crossAxisAlignment: CrossAxisAlignment.end,\n            children: <Widget>[\n              Text(\n                quote.lastPrice.toStringAsFixed(2),\n                style: const TextStyle(fontWeight: FontWeight.bold),\n              ),\n              Text(\n                '''${isPositive ? '+' : ''}${quote.priceChangePct.toStringAsFixed(2)}%''',\n                style: TextStyle(\n                  color: isPositive ? Colors.green : Colors.red,\n                  fontSize: 12,\n                ),\n              ),\n            ],\n          ),\n          IconButton(\n            icon: Icon(\n              isFavorite ? Icons.star : Icons.star_outline,\n              color: isFavorite ? Colors.amber : Colors.grey,\n            ),\n            onPressed: () =>\n                context.read<FavoritesNotifier>().toggleFavorite(quote.symbol),\n          ),\n        ],\n      ),\n      onTap: () => context.router.push(DetailRoute(quote: quote)),\n    );\n  }\n}"},"metrics":[{"metricsId":"number-of-methods","value":2,"unitType":"methods","level":"none","comment":"This class has 2 methods.","context":[{"message":"constructor QuoteTile increase metric value","codeSpan":{"start":{"offset":515,"line":12,"column":3},"end":{"offset":565,"line":12,"column":53},"text":"const QuoteTile({required this.quote, super.key});"}},{"message":"method build increase metric value","codeSpan":{"start":{"offset":657,"line":18,"column":3},"end":{"offset":2100,"line":59,"column":4},"text":"Widget build(final BuildContext context) {\n    final bool isPositive = quote.priceChangePct >= 0;\n    final bool isFavorite = context.watch<FavoritesNotifier>().isFavorite(\n      quote.symbol,\n    );\n\n    return ListTile(\n      title: Text(quote.symbol),\n      subtitle: Text('Vol: ${quote.quoteVolume.toStringAsFixed(2)}'),\n      trailing: Row(\n        mainAxisSize: MainAxisSize.min,\n        children: <Widget>[\n         